# Copy this file to `.env` for local Nuxt development.
# Production hosts usually set these values in their environment dashboard.

# --- Nuxt app / browser ---
# Public Convex deployment URL used for reads, and by the Nuxt server for writes.
# Local dev: set this to the URL printed by `pnpm convex:dev`.
# Production: set this to your Convex production deployment URL.
NUXT_PUBLIC_CONVEX_URL=

# Canonical frontend URL. The Nuxt server uses this for write-origin checks.
# Local dev can stay as-is. Production should be your deployed app URL.
NUXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# Optional comma-separated list of extra origins allowed to call Nuxt write APIs.
# Defaults include NUXT_PUBLIC_APP_BASE_URL, http://localhost:3000, and
# http://127.0.0.1:3000.
NUXT_ALLOWED_ORIGINS=

# --- Shared Nuxt + Convex write gate ---
# Required for startSession, submitAnswer, and completeSession.
# Set the exact same value in both places:
# - Nuxt hosting environment
# - Convex deployment environment
CONVEX_SERVER_SECRET=

# --- Convex runtime config admin ---
# Optional. Required only when calling the protected `config:updateAppConfig`
# Convex mutation. Set this in the Convex deployment environment.
CONFIG_ADMIN_SECRET=

# --- Convex CLI / CI deploy ---
# Optional. The Convex CLI may create CONVEX_DEPLOYMENT in `.env.local` for
# local development. CONVEX_DEPLOY_KEY is useful for non-interactive CI deploys.
CONVEX_DEPLOYMENT=
CONVEX_DEPLOY_KEY=

# --- Dataset generation only ---
# Not needed to run or deploy the app. These are used by scripts/dataset/*.
SPEC_MODEL=
AI_MODEL=
CODEX_DATASET_MODEL=
CODEX_DATASET_START=0
CODEX_DATASET_LIMIT=
CODEX_DATASET_OVERWRITE=0
CODEX_BIN=
